	// Highlight locked blocks in red.
	"highlightLocked": true,
	"inventorySkillLevel": true,
	"inventorySkillLevelPosX": -3,
	"inventorySkillLevelPosY": 0,
	"showLevelList": true,
	"showLevel": true,
	// Switch levelz screen instead of closing with inventory key
