{
	// Maximum level: 0 = disabled
	"overallMaxLevel": 0,
	// In combination with overallMaxLevel, only when all skills maxed
	"allowHigherSkillLevel": false,
	"startPoints": 10,
	"pointsPerLevel": 3,
	/* If true will reset stats on death 
	   !!!deprecated, not in use!!!
	*/
	"hardMode": false,
	// Retain % of levels and skill points, 0 = hard mode
	"levelRetainPercentage": 100.0,
	"disableMobFarms": false,
	// Amount of allowed mob kills in a chunk
	"mobKillCount": 600,
	// Strange potion resets all stats instead of one
	"opStrangePotion": false,
	// restrict hand usage when item not unlocked
	"lockedHandUsage": false,
	// Bonus id: bowDamage
	"bowDamageBonus": 0.10000000149011612,
	// Bonus id: bowDoubleDamageChance
	"bowDoubleDamageChanceBonus": 0.02500000037252903,
